---
import HoverTasks from "./HoverTasks.astro";
import { totalTarefasAbertas } from "../../data/tarefas-escritorio";

export type PersonaKind = "nucleo" | "exec" | "orbit" | "client" | "agent";
export type StatusDot = "online" | "busy" | "offline" | "running" | "idle" | "dormente";

interface Props {
  ownerId: string;
  ownerKind: "human" | "agent";
  iniciais: string;
  nome: string;
  papel: string;
  kind: PersonaKind;
  status?: StatusDot;
  dim?: boolean;
  badgeUrgent?: boolean;
}

const { ownerId, ownerKind, iniciais, nome, papel, kind, status = "online", dim = false, badgeUrgent = false } = Astro.props;
const total = totalTarefasAbertas(ownerId);

const statusClass = status === "busy" ? "busy"
  : status === "offline" ? "offline"
  : status === "running" ? "running"
  : status === "dormente" ? "offline"
  : status === "idle" ? "busy"
  : "online";
---

<div class:list={["qg-card", `k-${kind}`, dim && "dim", ownerKind === "agent" && "is-agent"]}>
  <div class="av">
    <span>{iniciais}</span>
    <span class:list={["dot-status", statusClass]}></span>
  </div>
  <div class="info">
    <div class="nm">{nome}</div>
    <div class="ro">{papel}</div>
  </div>
  {total > 0 && (
    <span class:list={["badge", badgeUrgent && "urgent"]}>{total}</span>
  )}
  <HoverTasks ownerId={ownerId} ownerKind={ownerKind} />
</div>

<style>
  .qg-card {
    background: var(--color-muted);
    border: 1px solid var(--color-line);
    border-radius: 10px;
    padding: 8px 10px;
    display: flex; gap: 8px; align-items: center;
    min-width: 180px;
    flex: 1 1 200px;
    cursor: pointer;
    position: relative;
    transition: all .12s;
  }
  .qg-card:hover { border-color: var(--color-info-border); box-shadow: 0 8px 24px -12px rgba(0,0,0,.18); z-index: 5; }
  .qg-card.dim { opacity: .55; }

  .av {
    width: 30px; height: 30px; border-radius: 50%;
    flex: 0 0 30px;
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-weight: 700; font-size: 11px;
    position: relative;
  }
  .qg-card.k-nucleo .av { background: var(--color-avatar-socio); }
  .qg-card.k-exec   .av { background: var(--color-avatar-executor); }
  .qg-card.k-orbit  .av { background: var(--color-avatar-hibrida); }
  .qg-card.k-client .av { background: var(--color-avatar-cliente); }
  .qg-card.k-agent  .av { background: #1a1a18; }
  .qg-card.dim .av { background: #9aa0a6; }

  .dot-status {
    position: absolute; right: -1px; bottom: -1px;
    width: 9px; height: 9px; border-radius: 50%;
    border: 1.5px solid var(--color-muted);
    background: #16a34a;
  }
  .dot-status.busy    { background: #d97706; }
  .dot-status.offline { background: #9aa0a6; }
  .dot-status.running { background: #16a34a; animation: pulseGreen 1.5s ease-out infinite; }

  .info { min-width: 0; flex: 1; }
  .nm { font-size: 12.5px; font-weight: 600; color: var(--color-base); margin: 0; }
  .ro { font-size: 10.5px; color: var(--color-faint); margin-top: 1px; }
  .qg-card.is-agent .nm:before { content: '⚡'; margin-right: 3px; color: var(--color-faint); font-size: 9px; }

  .badge {
    font-size: 10px; padding: 1px 5px; border-radius: 4px;
    background: var(--color-info-bg); color: var(--color-info-text);
    font-weight: 600;
  }
  .badge.urgent { background: var(--color-danger-bg); color: var(--color-danger-text); }

  @keyframes pulseGreen { 0%,100%{opacity:1} 50%{opacity:.55} }
</style>
