---
import { tarefasDe, type TarefaEscritorio } from "../../data/tarefas-escritorio";

interface Props {
  ownerId: string;
  ownerKind: "human" | "agent";
  emptyText?: string;
}
const { ownerId, ownerKind, emptyText = "Sem tarefas hoje" } = Astro.props;

const tarefas = tarefasDe(ownerId).slice(0, 5);
const detalhe = ownerKind === "human" ? `/pessoas#${ownerId}` : `/agentes#${ownerId}`;

function pri(t: TarefaEscritorio): string {
  if (t.state === "fazendo" && t.assignedKind === "agent") return "run";
  if (t.priority === "critica" || t.priority === "alta") return "high";
  if (t.priority === "media") return "med";
  return "";
}
function priChar(t: TarefaEscritorio): string {
  if (t.state === "fazendo" && t.assignedKind === "agent") return "▸";
  if (t.priority === "critica" || t.priority === "alta") return "!";
  return "·";
}
---

<div class="hover-pop">
  <h6>{tarefas.length === 0 ? emptyText : `${tarefas.length} tarefa${tarefas.length === 1 ? "" : "s"} hoje`}</h6>
  {tarefas.length > 0 && (
    <ul>
      {tarefas.map((t) => (
        <li>
          <span class:list={["pri", pri(t)]}>{priChar(t)}</span>
          <div class="bd">
            <b>{t.title}</b>
            {t.parentDecisionId && <div class="from">de uma decisão pendente</div>}
            {t.dueAt && <div class="from">prazo · {t.dueAt}</div>}
          </div>
        </li>
      ))}
    </ul>
  )}
  <a class="more" href={detalhe}>Ver todas →</a>
</div>

<style>
  .hover-pop {
    display: none;
    position: absolute;
    left: 100%;
    top: 0;
    margin-left: 8px;
    z-index: 50;
    width: 280px;
    background: #1a1a18;
    color: #fff;
    border-radius: 10px;
    padding: 12px 14px;
    box-shadow: 0 16px 40px -10px rgba(0,0,0,.45);
    font-size: 12px;
  }
  :global(.qg-card:hover) > .hover-pop,
  :global(.qg-card:focus-within) > .hover-pop {
    display: block;
  }
  .hover-pop:after {
    content: '';
    position: absolute;
    left: -6px;
    top: 14px;
    width: 0; height: 0;
    border-top: 6px solid transparent;
    border-bottom: 6px solid transparent;
    border-right: 6px solid #1a1a18;
  }
  .hover-pop h6 {
    font-size: 10.5px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: rgba(255,255,255,.55);
    margin: 0 0 6px;
  }
  .hover-pop ul { margin: 0; padding: 0; list-style: none; }
  .hover-pop ul li {
    padding: 5px 0;
    font-size: 12px;
    line-height: 1.4;
    border-bottom: 1px solid rgba(255,255,255,.08);
    display: flex; gap: 8px; align-items: flex-start;
  }
  .hover-pop ul li:last-child { border-bottom: 0; }
  .hover-pop .pri {
    font-size: 9px;
    padding: 1px 5px;
    border-radius: 3px;
    background: rgba(255,255,255,.15);
    flex: 0 0 auto;
    margin-top: 1px;
    color: #fff;
  }
  .hover-pop .pri.high { background: #dc2626; }
  .hover-pop .pri.med  { background: #d97706; }
  .hover-pop .pri.run  { background: #16a34a; animation: pulseGreen 1.5s ease-out infinite; }
  .hover-pop .bd b { font-weight: 600; }
  .hover-pop .from { opacity: .65; font-size: 11px; margin-top: 1px; }
  .hover-pop .more {
    display: block;
    font-size: 10.5px;
    color: rgba(255,255,255,.55);
    text-align: center;
    padding: 6px 0 0;
    cursor: pointer;
  }
  .hover-pop .more:hover { color: #fff; }

  @keyframes pulseGreen { 0%,100%{opacity:1} 50%{opacity:.55} }

  @media (max-width: 640px) {
    .hover-pop { left: 0; top: 100%; margin-left: 0; margin-top: 8px; width: min(280px, calc(100vw - 60px)); }
    .hover-pop:after { display: none; }
  }
</style>
