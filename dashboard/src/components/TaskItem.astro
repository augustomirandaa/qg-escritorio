---
import type { Tarefa } from "../data/types";
import { pessoaById } from "../data/pessoas";

interface Props { tarefa: Tarefa; }
const { tarefa } = Astro.props;
const pessoa = pessoaById(tarefa.responsavelId);

const statusLabel = {
  "pendente": "pendente",
  "em-progresso": "em progresso",
  "feita": "feita",
}[tarefa.status];

const statusClass = {
  "pendente": "s-neutral",
  "em-progresso": "s-info",
  "feita": "s-success",
}[tarefa.status];
---

<div class:list={["task", `task-${tarefa.status}`]}>
  <div class="flex items-start gap-2.5">
    <div class="checkbox" aria-hidden="true">
      {tarefa.status === "feita" && (
        <svg viewBox="0 0 14 14" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="2,7 6,11 12,3"></polyline>
        </svg>
      )}
      {tarefa.status === "em-progresso" && (
        <span class="dot-progress"></span>
      )}
    </div>
    <div class="flex-1 min-w-0">
      <div class:list={["text-[13px] font-medium leading-snug", tarefa.status === "feita" && "line-through text-faint"]}>{tarefa.titulo}</div>
      {tarefa.porQue && (
        <div class="por-que mt-1.5">
          <span class="por-que-label">por quê</span>
          <span class="por-que-text">{tarefa.porQue}</span>
        </div>
      )}
      <div class="flex items-center gap-2 mt-2 flex-wrap">
        {pessoa ? (
          <span class="resp-pill">
            <span class:list={["av-mini", `t-${pessoa.tipo}`]}>{pessoa.iniciais}</span>
            <span class="text-[11px] text-soft">{pessoa.nome}</span>
          </span>
        ) : (
          <span class="text-[11px] text-faint italic">sem responsável</span>
        )}
        <span class={`status-badge ${statusClass}`}>{statusLabel}</span>
      </div>
    </div>
  </div>
  {tarefa.notas && <p class="text-[11px] text-soft leading-snug mt-2 ml-7">{tarefa.notas}</p>}
</div>

<style>
  .task {
    padding: 10px 12px;
    background: var(--color-muted);
    border-radius: 8px;
    border-left: 3px solid transparent;
  }
  .task-pendente { border-left-color: var(--color-faint); }
  .task-em-progresso { border-left-color: var(--color-info-border); }
  .task-feita { border-left-color: var(--color-success-text); opacity: 0.65; }

  .checkbox {
    width: 16px;
    height: 16px;
    border: 1.5px solid var(--color-faint);
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 1px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-success-text);
  }
  .task-feita .checkbox {
    background: var(--color-success-text);
    border-color: var(--color-success-text);
    color: #fff;
  }
  .task-em-progresso .checkbox {
    border-color: var(--color-info-border);
    border-style: dashed;
  }
  .dot-progress {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-info-border);
  }

  .resp-pill {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 2px 8px 2px 2px;
    background: var(--color-surface);
    border-radius: 999px;
    border: 0.5px solid var(--color-line);
  }
  .av-mini {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 9px;
    font-weight: 500;
    color: #fff;
  }
  .av-mini.t-socio { background: var(--color-avatar-socio); }
  .av-mini.t-hibrida { background: var(--color-avatar-hibrida); }
  .av-mini.t-executor { background: var(--color-avatar-executor); }
  .av-mini.t-network { background: var(--color-avatar-network); }
  .av-mini.t-cliente { background: var(--color-avatar-cliente); }

  .por-que {
    display: block;
    padding: 6px 9px;
    background: var(--color-surface);
    border-left: 2px solid var(--color-info-border);
    border-radius: 0 4px 4px 0;
    font-size: 11px;
    color: var(--color-soft);
    line-height: 1.45;
  }
  .por-que-label {
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--color-info-text);
    font-weight: 500;
    margin-right: 6px;
  }
  .por-que-text {
    color: var(--color-base);
  }
</style>
