---
import "../styles/global.css";
import Header from "../components/Header.astro";

interface Props {
  title: string;
  subtitle?: string;
  versao?: string;
}

const { title, subtitle, versao = "v2.0 · 25 abr 2026" } = Astro.props;
const pageTitle = title.toLowerCase().includes("qg") ? title : `${title} · QG`;
---

<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{pageTitle}</title>
</head>
<body>
  <div class="mx-auto max-w-[960px] px-5 pt-6 pb-12">
    <Header />
    <main>
      <header class="flex flex-wrap items-start justify-between gap-3 border-b border-line pb-4 mb-6">
        <div>
          <h1 class="text-[22px] font-medium leading-tight m-0">{title}</h1>
          {subtitle && <p class="text-[13px] text-soft mt-1 m-0">{subtitle}</p>}
        </div>
        <div class="text-[11px] text-faint bg-muted px-2.5 py-1 rounded-md whitespace-nowrap">{versao}</div>
      </header>
      <slot />
    </main>
    <footer class="mt-8 px-4 py-3.5 bg-muted rounded-md text-[11px] text-soft leading-relaxed">
      <strong class="text-base font-medium">QG · Centro de operações.</strong>
      Brochure manual · atualiza-se via commit no repo <code class="bg-canvas px-1.5 py-0.5 rounded text-[10px]">qg-escritorio</code>.
      Versão viva (com dados em tempo real) virá após a Fase 1 da plataforma.
    </footer>
  </div>
</body>
</html>
