---
import Base from "../layouts/Base.astro";
import { AGENTES, AGENTES_POR_AREA, TOTAL_AGENTES, ATIVOS_FASE_0 } from "../data/agentes";
import { AREA_NOMES } from "../data/types";
import { PROJETOS } from "../data/projetos";
import type { AreaKey } from "../data/types";

const areas = Object.keys(AGENTES_POR_AREA) as AreaKey[];

const ativosP2 = AGENTES.filter(a => a.fase === "ativo" && a.prioridade === 2).length;
const adiados = AGENTES.filter(a => a.fase === "dormente" || a.fase === "futuro").length;
---

<Base
  title="Agentes IA"
  subtitle={`${TOTAL_AGENTES} agentes mapeados · ${ATIVOS_FASE_0} em uso ativo nas próximas 4-6 semanas`}
>
  <div class="grid grid-cols-2 md:grid-cols-4 gap-2.5 mb-6">
    <div class="bg-muted px-3.5 py-3 rounded-md">
      <div class="text-[20px] font-medium leading-none">{TOTAL_AGENTES}</div>
      <div class="text-[11px] text-soft mt-1">total mapeados</div>
    </div>
    <div class="bg-success-bg px-3.5 py-3 rounded-md">
      <div class="text-[20px] font-medium leading-none text-success-text">{ATIVOS_FASE_0}</div>
      <div class="text-[11px] text-success-text/80 mt-1">ativos agora</div>
    </div>
    <div class="bg-warning-bg px-3.5 py-3 rounded-md">
      <div class="text-[20px] font-medium leading-none text-warning-text">{ativosP2}</div>
      <div class="text-[11px] text-warning-text/80 mt-1">ativos planejados</div>
    </div>
    <div class="bg-neutral-bg px-3.5 py-3 rounded-md">
      <div class="text-[20px] font-medium leading-none text-neutral-text">{adiados}</div>
      <div class="text-[11px] text-neutral-text/80 mt-1">dormentes / pós-saída</div>
    </div>
  </div>

  {areas.map((area) => {
    const lista = AGENTES_POR_AREA[area];
    if (!lista.length) return null;
    return (
      <section class="mb-7">
        <h2 class:list={["text-[14px] font-medium mb-3 inline-flex items-center gap-2", `area-h-${area}`]}>
          <span class="w-2.5 h-2.5 rounded-full"></span>
          {AREA_NOMES[area]} <span class="text-faint font-normal">· {lista.length}</span>
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          {lista.map((a) => (
            <div class="panel">
              <div class="flex items-baseline justify-between gap-2 mb-1">
                <div class="text-[14px] font-medium leading-tight">{a.nome}</div>
                {a.fase === "ativo" && a.prioridade === 1 && (
                  <span class="status-badge s-success" title="Em uso ativo nesta fase">ativo agora</span>
                )}
                {a.fase === "ativo" && a.prioridade === 2 && (
                  <span class="status-badge s-warning" title="Já configurado, ativa quando o modelo precisar">ativo planejado</span>
                )}
                {a.fase === "dormente" && (
                  <span class="status-badge s-neutral" title="Não está em uso ainda · ativa em fase futura">dormente</span>
                )}
                {a.fase === "futuro" && (
                  <span class="status-badge s-neutral" title="Só ativa após a saída do Augusto do grupo Primordialle">pós-saída</span>
                )}
              </div>
              <p class="text-[12px] text-soft leading-snug m-0 mb-3">{a.funcao}</p>
              <div class="flex items-center gap-1 flex-wrap pt-2.5 border-t border-line">
                <span class="text-[10px] text-faint mr-1">aparece em:</span>
                {a.modelos.map((m) => (
                  <a
                    href={`/projetos/${m}`}
                    class="text-[10px] px-1.5 py-0.5 rounded bg-muted text-soft hover:bg-canvas hover:text-base transition-colors"
                    title={PROJETOS[m].secreto ? "Projeto protegido" : PROJETOS[m].apelido}
                  >
                    {m}
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>
    );
  })}
</Base>

<style>
  .area-h-diretoria span { background: var(--color-area-diretoria); }
  .area-h-marca span { background: var(--color-area-marca); }
  .area-h-comercial span { background: var(--color-area-comercial); }
  .area-h-ops span { background: var(--color-area-ops); }
  .area-h-tec span { background: var(--color-area-tec); }
  .area-h-conhecimento span { background: var(--color-area-conhecimento); }
</style>
