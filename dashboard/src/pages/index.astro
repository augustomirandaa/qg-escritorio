---
import Base from "../layouts/Base.astro";
import StatusBadge from "../components/StatusBadge.astro";
import TaskItem from "../components/TaskItem.astro";
import { PROJETOS, PROJETO_IDS } from "../data/projetos";
import { ATIVOS_FASE_0 } from "../data/agentes";
import { formatarPrazo, hojeISO, ordenarTarefas } from "../data/tarefa-utils";
import type { Tarefa, ProjetoId } from "../data/types";

const hoje = hojeISO();

// Agrega tarefas globais com info de projeto pra cada
interface TarefaGlobal extends Tarefa { __projeto: ProjetoId; __projetoLabel: string; __projetoSecreto: boolean; }
const todasTarefas: TarefaGlobal[] = PROJETO_IDS.flatMap((pid) => {
  const p = PROJETOS[pid];
  return p.tarefas.map((t) => ({
    ...t,
    __projeto: pid,
    __projetoLabel: p.secreto ? `Projeto ${pid}` : `${pid} · ${p.apelido}`,
    __projetoSecreto: !!p.secreto,
  }));
});

// Stats de atenção
const tarefasAbertas = todasTarefas.filter((t) => t.status !== "feita");
const atrasadas = tarefasAbertas.filter((t) => formatarPrazo(t.prazo, hoje)?.urgencia === "atrasada");
const paraHoje = tarefasAbertas.filter((t) => {
  const f = formatarPrazo(t.prazo, hoje);
  return f?.urgencia === "hoje";
});
const proximos7 = ordenarTarefas(
  tarefasAbertas.filter((t) => {
    const f = formatarPrazo(t.prazo, hoje);
    return f && (f.urgencia === "hoje" || f.urgencia === "amanha" || f.urgencia === "proxima-semana");
  })
) as TarefaGlobal[];

// Por projeto: contagens pra cada card
function statsProjeto(pid: ProjetoId) {
  const ts = PROJETOS[pid].tarefas;
  return {
    atrasadas: ts.filter((t) => t.status !== "feita" && formatarPrazo(t.prazo, hoje)?.urgencia === "atrasada").length,
    pendentes: ts.filter((t) => t.status === "pendente").length,
    progresso: ts.filter((t) => t.status === "em-progresso").length,
    feitas: ts.filter((t) => t.status === "feita").length,
    total: ts.length,
  };
}
---

<Base
  title="QG · Centro de operações"
  subtitle="Estado do portfólio · o que precisa de atenção e quem opera o quê"
>
  {/* ═══ ATENÇÃO PRECISA ═══ */}
  <section class="mb-7">
    <h2 class="section-h mb-3">Atenção precisa</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-2.5">
      <a
        href="/tarefas"
        class:list={[
          "block px-3.5 py-3 rounded-md transition-colors",
          atrasadas.length > 0
            ? "bg-danger-bg hover:bg-danger-text/10 border-l-[3px] border-danger-text"
            : "bg-muted hover:bg-canvas",
        ]}
      >
        <div class:list={["text-[22px] font-medium leading-none", atrasadas.length > 0 ? "text-danger-text" : "text-soft"]}>
          {atrasadas.length}
        </div>
        <div class:list={["text-[11px] mt-1 leading-snug", atrasadas.length > 0 ? "text-danger-text" : "text-soft"]}>
          {atrasadas.length === 1 ? "tarefa atrasada" : "tarefas atrasadas"}
        </div>
      </a>

      <a
        href="/tarefas"
        class:list={[
          "block px-3.5 py-3 rounded-md transition-colors",
          paraHoje.length > 0
            ? "bg-warning-bg hover:bg-warning-text/10 border-l-[3px] border-warning-text"
            : "bg-muted hover:bg-canvas",
        ]}
      >
        <div class:list={["text-[22px] font-medium leading-none", paraHoje.length > 0 ? "text-warning-text" : "text-soft"]}>
          {paraHoje.length}
        </div>
        <div class:list={["text-[11px] mt-1 leading-snug", paraHoje.length > 0 ? "text-warning-text" : "text-soft"]}>
          {paraHoje.length === 1 ? "tarefa pra hoje" : "tarefas pra hoje"}
        </div>
      </a>

      <a href="/tarefas" class="block bg-muted hover:bg-canvas px-3.5 py-3 rounded-md transition-colors">
        <div class="text-[22px] font-medium leading-none">{tarefasAbertas.length}</div>
        <div class="text-[11px] text-soft mt-1 leading-snug">tarefas em aberto</div>
      </a>

      <a href="/agentes" class="block bg-muted hover:bg-canvas px-3.5 py-3 rounded-md transition-colors">
        <div class="text-[22px] font-medium leading-none">{ATIVOS_FASE_0}</div>
        <div class="text-[11px] text-soft mt-1 leading-snug">agentes ativos agora</div>
      </a>
    </div>
  </section>

  {/* ═══ OS 6 MODELOS ═══ */}
  <section class="mb-7">
    <h2 class="section-h mb-3">Os 6 modelos do portfólio</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
      {PROJETO_IDS.map((id) => {
        const p = PROJETOS[id];
        if (p.secreto) {
          return (
            <a
              href={`/projetos/${id}`}
              class="block panel hover:border-line-strong transition-colors secret-card"
              title="Projeto protegido · clique pra inserir senha"
            >
              <div class="flex items-center justify-between gap-3">
                <div class="flex items-baseline gap-2.5">
                  <span class="text-[20px] font-medium leading-none">{id}</span>
                  <span class="text-[14px] font-medium text-soft">Projeto {id}</span>
                </div>
                <span class="inline-flex items-center gap-1 text-[11px] text-warning-text bg-warning-bg px-2 py-1 rounded">
                  <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                  </svg>
                  protegido
                </span>
              </div>
            </a>
          );
        }
        const s = statsProjeto(id);
        return (
          <a href={`/projetos/${id}`} class="block panel hover:border-line-strong transition-colors">
            <div class="flex items-baseline justify-between gap-3 mb-1.5">
              <div class="flex items-baseline gap-2.5">
                <span class="text-[20px] font-medium leading-none">{id}</span>
                <span class="text-[14px] font-medium">{p.apelido}</span>
              </div>
              <StatusBadge status={p.status} statusClass={p.statusClass} />
            </div>
            <p class="text-[12px] text-soft leading-snug m-0">{p.meta}</p>
            <div class="flex items-center gap-3 mt-3 text-[11px] flex-wrap">
              {s.atrasadas > 0 && (
                <span class="text-danger-text font-medium">
                  ● {s.atrasadas} {s.atrasadas === 1 ? "atrasada" : "atrasadas"}
                </span>
              )}
              {s.pendentes > 0 && (
                <span class="text-soft">○ {s.pendentes} a fazer</span>
              )}
              {s.progresso > 0 && (
                <span class="text-info-text">◐ {s.progresso} em progresso</span>
              )}
              {s.feitas > 0 && (
                <span class="text-faint">✓ {s.feitas}</span>
              )}
              {s.total === 0 && (
                <span class="text-faint italic">sem tarefas registradas</span>
              )}
            </div>
          </a>
        );
      })}
    </div>
  </section>

  {/* ═══ PRÓXIMOS 7 DIAS ═══ */}
  {proximos7.length > 0 && (
    <section class="mb-2">
      <div class="flex items-baseline justify-between mb-3 gap-3 flex-wrap">
        <h2 class="section-h">Próximos 7 dias</h2>
        <a href="/tarefas" class="text-[11px] text-soft hover:text-base">ver todas as tarefas →</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
        {proximos7.slice(0, 8).map((t) => (
          <TaskItem
            tarefa={t}
            projetoLabel={t.__projetoLabel}
            projetoHref={`/projetos/${t.__projeto}`}
          />
        ))}
      </div>
      {proximos7.length > 8 && (
        <p class="text-[11px] text-faint mt-3 text-center">
          + {proximos7.length - 8} {proximos7.length - 8 === 1 ? "tarefa" : "tarefas"} nos próximos 7 dias
        </p>
      )}
    </section>
  )}
</Base>
