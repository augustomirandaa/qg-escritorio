---
import Base from "../layouts/Base.astro";
import { MATRIZ } from "../data/matriz";
import { PROJETOS, PROJETO_IDS } from "../data/projetos";
---

<Base
  title="Matriz · agentes × modelos"
  subtitle="Onde cada agente toca · 21 agentes × 6 modelos"
>
  <div class="panel overflow-x-auto">
    <div class="matrix">
      <div class="m-h m-h-area">Agente</div>
      {PROJETO_IDS.map((id) => (
        <div class="m-h" title={PROJETOS[id].secreto ? "Projeto protegido" : PROJETOS[id].apelido}>{id}</div>
      ))}
      {MATRIZ.map((bloco) => (
        <>
          <div class="m-area">{bloco.area}</div>
          {bloco.linhas.map((l) => (
            <>
              <div class="m-label">{l.agente}</div>
              {PROJETO_IDS.map((id) => {
                const cell = l.celulas[id];
                return (
                  <div class="m-cell">
                    {cell === "ativo" && <span class="mark active" title="ativo · prioridade 1"></span>}
                    {cell === "dormente" && <span class="mark dormant" title="dormente · ativa em fase futura"></span>}
                  </div>
                );
              })}
            </>
          ))}
        </>
      ))}
    </div>

    <div class="flex gap-5 text-[11px] text-soft mt-4 pt-3 border-t border-line flex-wrap">
      <div class="flex items-center gap-1.5">
        <span class="mark active"></span> ativo · prioridade 1
      </div>
      <div class="flex items-center gap-1.5">
        <span class="mark dormant"></span> dormente · ativa em fase futura
      </div>
    </div>
  </div>

  <div class="mt-4 grid grid-cols-2 md:grid-cols-6 gap-2">
    {PROJETO_IDS.map((id) => (
      <a
        href={`/projetos/${id}`}
        class="block bg-surface border-[0.5px] border-line rounded-md px-3 py-2 hover:bg-muted transition-colors"
      >
        <div class="text-[14px] font-medium leading-tight">{id}</div>
        <div class="text-[10px] text-soft mt-0.5 leading-tight">
          {PROJETOS[id].secreto ? "protegido" : PROJETOS[id].apelido}
        </div>
      </a>
    ))}
  </div>
</Base>

<style>
  .matrix {
    display: grid;
    grid-template-columns: 200px repeat(6, 1fr);
    gap: 2px;
    font-size: 11px;
    min-width: 600px;
  }
  .m-h {
    font-weight: 500;
    padding: 8px 4px;
    text-align: center;
    color: var(--color-soft);
    font-size: 12px;
  }
  .m-h-area {
    text-align: left;
    padding-left: 10px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-size: 10px;
  }
  .m-area {
    grid-column: 1 / -1;
    padding: 14px 10px 4px;
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    color: var(--color-soft);
    border-top: 0.5px solid var(--color-line);
  }
  .m-area:first-of-type { border-top: none; padding-top: 4px; }
  .m-label {
    padding: 7px 10px;
    font-size: 12px;
    color: var(--color-base);
    display: flex;
    align-items: center;
  }
  .m-cell {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6px 4px;
    min-height: 28px;
    border-radius: 4px;
  }
  .mark {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    display: inline-block;
  }
  .mark.active { background: #1d9e75; }
  .mark.dormant { background: transparent; border: 1.5px solid #888780; }

  @media (max-width: 640px) {
    .matrix { grid-template-columns: 130px repeat(6, 1fr); font-size: 10px; }
  }
</style>
