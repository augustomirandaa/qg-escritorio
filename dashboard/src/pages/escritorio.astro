let currentSel = null;

function selectEntity(sel){
  currentSel = sel;
  document.querySelectorAll('.obj.selected').forEach(e=>e.classList.remove('selected'));
  layers.conn.innerHTML = '';
  if (!sel){
    panel.className = 'panel empty';
    panel.innerHTML = '<div>Clique em qualquer pessoa, agente ou sala para ver o detalhe operacional aqui.</div>';
    document.getElementById('selectionBadge').style.display = 'none';
    return;
  }
  const node = svg.querySelector('[data-id="'+sel.id+'"]');
  if (node) node.classList.add('selected');
  document.getElementById('selectionBadge').style.display = 'flex';
  if (sel.type === 'agent') renderAgentPanel(sel.id);
  else if (sel.type === 'person') renderPersonPanel(sel.id);
  drawConnections(sel);
}
window.selectEntity = selectEntity;

