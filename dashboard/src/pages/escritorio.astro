---
import EscritorioBase from "../layouts/EscritorioBase.astro";
import { DECISOES } from "../data/decisoes";
import { TAREFAS_ESCRITORIO } from "../data/tarefas-escritorio";
import { AGENTES } from "../data/agentes";

const ativos = AGENTES.filter((a) => a.fase === "ativo").length;
const total = AGENTES.length;
const tarefasAbertas = TAREFAS_ESCRITORIO.filter((t) => t.state !== "concluida").length;

const priClass: Record<string, { box: string; pill: string; label: string }> = {
  critica: { box: "crit",  pill: "p-crit", label: "Crítica" },
  alta:    { box: "warn",  pill: "p-warn", label: "Alta" },
  media:   { box: "info",  pill: "p-info", label: "Média" },
  baixa:   { box: "info",  pill: "p-info", label: "Baixa" },
};
---

<EscritorioBase
  title="Decisões pendentes"
  subtitle="Operação por exceção. Você só entra quando precisa. Resto está rolando."
>
  <section data-decisoes-area>
    <h2 class="section-h mb-3" data-decisoes-h>
      <span data-decisoes-count>{DECISOES.length}</span> decisões aguardam você ·
      <span data-decisoes-crit>{DECISOES.filter((d) => d.priority === "critica").length}</span> crítica
    </h2>

    <div class="dp-list">
      {DECISOES.map((d) => (
        <article
          class:list={["dp-item", priClass[d.priority].box]}
          data-projeto={d.projectId}
          data-visibilidade={d.visibleTo.join(",")}
          data-decisao
          data-decisao-id={d.id}
        >
          <span class:list={["dp-priority", priClass[d.priority].pill]}>
            {priClass[d.priority].label}
          </span>
          <div class="dp-content">
            <h4 class="dp-title">{d.title}</h4>
            <p class="dp-context">{d.context}</p>
            <div class="dp-meta">
              <span>Disparado por: <b>{d.triggeredByLabel}</b></span>
              <span>Projeto: <b>{d.projectId}</b></span>
              <span>{d.ageLabel}</span>
            </div>
          </div>
          <div class="dp-actions">
            {d.options.map((o) => (
              <button
                type="button"
                class:list={["dp-btn", o.primary && "primary", o.danger && "danger"]}
                data-action={o.action}
              >
                {o.label}
              </button>
            ))}
          </div>
        </article>
      ))}
    </div>

    <div class="dp-empty" hidden>
      <strong>Tudo rolando sozinho.</strong> Sem decisões pendentes pra você no momento.
    </div>
  </section>

  <section class="border-t border-line pt-5 mt-5">
    <h5 class="section-h mb-3">Contexto · sem ação requerida</h5>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
      <div class="kpi"><div class="v">6</div><div class="l">projetos no portfólio</div></div>
      <div class="kpi"><div class="v">{ativos} / {total}</div><div class="l">agentes ativos</div></div>
      <div class="kpi"><div class="v">{tarefasAbertas}</div><div class="l">tarefas abertas</div></div>
    </div>
    <p class="dp-resumo">
      <b>Tudo o resto está rolando sozinho.</b> Conteúdo gerou 3 posts F (Pablo já foi notificado),
      CRM atualizou pipeline A, Tráfego escalou campanha Lumina ROI 2.3x. Sem alertas pra você ler.
    </p>
  </section>
</EscritorioBase>

<style>
  .dp-list { display: flex; flex-direction: column; gap: 10px; }
  .dp-item {
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: 10px;
    padding: 14px 16px;
    display: flex; gap: 12px; align-items: flex-start;
  }
  .dp-item.crit { border-left: 4px solid #dc2626; background: linear-gradient(90deg, rgba(252,235,235,.5) 0%, var(--color-surface) 30%); }
  .dp-item.warn { border-left: 4px solid #d97706; background: linear-gradient(90deg, rgba(250,238,218,.5) 0%, var(--color-surface) 30%); }
  .dp-item.info { border-left: 4px solid var(--color-info-border); background: linear-gradient(90deg, rgba(230,241,251,.5) 0%, var(--color-surface) 30%); }

  .dp-priority {
    font-size: 10px; font-weight: 700;
    text-transform: uppercase; letter-spacing: .1em;
    padding: 3px 8px; border-radius: 4px;
    flex: 0 0 auto;
    color: #fff;
  }
  .dp-priority.p-crit { background: #dc2626; }
  .dp-priority.p-warn { background: #d97706; }
  .dp-priority.p-info { background: var(--color-info-border); }

  .dp-content { flex: 1; min-width: 0; }
  .dp-title { font-size: 14px; font-weight: 600; margin: 0 0 4px; }
  .dp-context { font-size: 12.5px; color: var(--color-soft); margin: 0; line-height: 1.45; }
  .dp-meta {
    display: flex; gap: 8px; margin-top: 6px;
    font-size: 11px; color: var(--color-faint); flex-wrap: wrap;
  }
  .dp-meta b { color: var(--color-base); font-weight: 500; }

  .dp-actions { display: flex; gap: 6px; flex: 0 0 auto; margin-top: 2px; flex-wrap: wrap; }
  .dp-btn {
    font-size: 12px; padding: 6px 11px; border-radius: 6px;
    border: 1px solid var(--color-line-strong);
    background: var(--color-surface);
    cursor: pointer; white-space: nowrap;
  }
  .dp-btn.primary { background: #16a34a; color: #fff; border-color: #16a34a; }
  .dp-btn.danger  { background: var(--color-surface); color: var(--color-danger-text); border-color: rgba(220,38,38,.3); }
  .dp-btn[data-resolved] { opacity: .5; pointer-events: none; }

  .dp-empty {
    padding: 16px;
    background: var(--color-muted);
    border-radius: 10px;
    border: 1px dashed var(--color-line-strong);
    color: var(--color-soft);
    font-size: 13px;
  }
  .dp-empty strong { color: var(--color-base); }

  .dp-resumo {
    font-size: 12px; color: var(--color-soft); margin-top: 12px;
    padding: 10px 12px; background: var(--color-muted); border-radius: 8px;
  }

  .kpi { background: var(--color-muted); padding: 10px 12px; border-radius: 8px; }
  .kpi .v { font-size: 18px; font-weight: 600; }
  .kpi .l { font-size: 10.5px; color: var(--color-faint); text-transform: uppercase; letter-spacing: .05em; margin-top: 2px; }
</style>

<script is:inline>
  document.querySelectorAll("[data-decisao] .dp-btn").forEach((btn) => {
    btn.addEventListener("click", (ev) => {
      const action = btn.getAttribute("data-action");
      const item   = btn.closest("[data-decisao]");
      const id     = item.getAttribute("data-decisao-id");
      console.log("[decisao]", id, "→", action);
      item.querySelectorAll(".dp-btn").forEach((b) => b.setAttribute("data-resolved", ""));
      const tag = document.createElement("div");
      tag.className = "dp-meta";
      tag.style.marginTop = "8px";
      tag.style.color = "#16a34a";
      tag.textContent = "✓ Resolvido · " + (btn.textContent || "").trim();
      item.querySelector(".dp-content").appendChild(tag);
    });
  });

  // re-render contagem quando user troca
  function recountDecisoes(){
    const visiveis = Array.from(document.querySelectorAll("[data-decisao]")).filter((el) => !el.hasAttribute("hidden"));
    const total = visiveis.length;
    const crits = visiveis.filter((el) => el.classList.contains("crit")).length;
    const c = document.querySelector("[data-decisoes-count]");
    const cr = document.querySelector("[data-decisoes-crit]");
    if (c) c.textContent = String(total);
    if (cr) cr.textContent = String(crits);
    const empty = document.querySelector(".dp-empty");
    if (empty) empty.toggleAttribute("hidden", total > 0);
    const h = document.querySelector("[data-decisoes-h]");
    if (h) h.toggleAttribute("hidden", total === 0);
  }
  const select = document.querySelector("[data-qg-userselect]");
  if (select) select.addEventListener("change", () => setTimeout(recountDecisoes, 50));
  setTimeout(recountDecisoes, 50);
</script>
