  return '<div class="av" style="background:'+c+'">'+initials+'</div>';
}
function statusBadge(s){
  if (s==='P1') return '<span class="b green">ativo · P1</span>';
  if (s==='P2') return '<span class="b amber">ativo · P2</span>';
  if (s==='dorm') return '<span class="b dorm">dormente</span>';
  if (s==='online') return '<span class="b green">online</span>';
  if (s==='busy') return '<span class="b amber">ocupado</span>';
  if (s==='offline') return '<span class="b dorm">offline</span>';
  return '';
}
function modelChips(models){
  return (models||[]).map(m=>'<span class="b model">'+m+'</span>').join('');
}
function sparklineSVG(data){
  if (!data.length) return '';
  const max = Math.max.apply(null, data.concat([1])), min = Math.min.apply(null, data.concat([0]));
  const w = 200, h = 32, pad = 2;
  const step = (w - pad*2) / (data.length - 1 || 1);
  const points = data.map((v,i)=>[pad + i*step, h - pad - ((v-min)/(max-min || 1)) * (h - pad*2)]);
  const path = points.map((p,i)=>(i?'L':'M')+p[0]+' '+p[1]).join(' ');
  const fillPath = path + ' L '+(w-pad)+' '+(h-pad)+' L '+pad+' '+(h-pad)+' Z';
  return '<svg class="spark" viewBox="0 0 '+w+' '+h+'" xmlns="http://www.w3.org/2000/svg"><path d="'+fillPath+'" fill="rgba(24,95,165,0.12)"/><path d="'+path+'" fill="none" stroke="var(--eo-blue)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>';
}
function renderAgentPanel(id){
  const a = AGENT_BY_ID[id]; if (!a) return;
  const room = ROOM_BY_KEY[a.dept];
  const supervisors = (a.supervisor||[]).map(pid => PERSON_BY_ID[pid]).filter(Boolean);
  const series = Array.from({length: 14}, ()=> Math.round(Math.random() * (a.invocations*0.9 + 4)));
  panel.className = 'panel';
  panel.innerHTML =
    '<div class="panel-head">'+
      avatarHTML(a.name.split(/\s+/).map(s=>s[0]).join('').slice(0,2).toUpperCase(),'agent')+
      '<div>'+
        '<h3 class="name">'+a.name+'</h3>'+
        '<div class="role">Agente IA · '+(room ? room.label : '')+'</div>'+
        '<div class="badge-list" style="margin-top:6px">'+statusBadge(a.status)+(a.running?'<span class="b green">rodando agora</span>':'')+modelChips(a.models)+'</div>'+
      '</div>'+
      '<button class="close" id="panelClose" aria-label="Fechar">×</button>'+
    '</div>'+
    '<div class="panel-body">'+
      '<div class="panel-section"><p>'+a.desc+'</p></div>'+
      '<div class="panel-section">'+
        '<h4>Operação</h4>'+
        '<div class="metric">'+
          '<div class="m"><div class="v">'+a.invocations+'</div><div class="l">invocações · 7d</div></div>'+
          '<div class="m"><div class="v">'+a.success+'%</div><div class="l">sucesso</div></div>'+
          '<div class="m"><div class="v" style="font-size:13px; padding-top:3px">'+a.lastRun+'</div><div class="l">última execução</div></div>'+
        '</div>'+
        sparklineSVG(series)+
      '</div>'+
      '<div class="panel-section">'+
        '<h4>Humanos próximos</h4>'+
        '<div class="related">'+
          (supervisors.length ? supervisors.map(p=>'<div class="row" data-jump="person:'+p.id+'">'+avatarHTML(p.initials, p.kind)+'<div><div class="meta">'+p.name+'</div><div class="submeta">'+p.role+'</div></div></div>').join('') : '<div style="font-size:12px; color:var(--eo-ink-faint)">Sem supervisor designado</div>')+
        '</div>'+
      '</div>'+
      '<div class="panel-section">'+
        '<h4>Ações</h4>'+
        '<div class="actions">'+
          '<button class="btn primary">▶ Rodar agora</button>'+
          '<button class="btn">Ver logs</button>'+
          '<button class="btn">Editar prompt</button>'+
          '<button class="btn">Pausar</button>'+
        '</div>'+
      '</div>'+
    '</div>';
  attachPanelHandlers();
  document.getElementById('selectionName').textContent = a.name;
}
function statusLabelTxt(a){
  const m = (a.models||[]).join(', ');
  const s = a.status==='P1'?'P1':a.status==='P2'?'P2':'dormente';
  return s + ' · modelos: ' + (m||'—');
}
function renderPersonPanel(id){
  const p = PERSON_BY_ID[id]; if (!p) return;
  const room = ROOM_BY_KEY[p.dept];
  const agents = (p.supervisesAgents||[]).map(aid => AGENT_BY_ID[aid]).filter(Boolean);
  panel.className = 'panel';
  panel.innerHTML =
    '<div class="panel-head">'+
      avatarHTML(p.initials, p.kind)+
      '<div>'+
        '<h3 class="name">'+p.name+'</h3>'+
        '<div class="role">'+p.role+'</div>'+
        '<div class="badge-list" style="margin-top:6px">'+statusBadge(p.status)+modelChips(p.models)+(p.salary?'<span class="b outline">'+p.salary+'</span>':'')+'</div>'+
      '</div>'+
      '<button class="close" id="panelClose" aria-label="Fechar">×</button>'+
    '</div>'+
    '<div class="panel-body">'+
      '<div class="panel-section"><p>'+p.desc+'</p></div>'+
      '<div class="panel-section"><h4>Sala / departamento</h4><div class="kv"><dt>Localização</dt><dd>'+(room ? room.label : '—')+'</dd></div></div>'+
      '<div class="panel-section"><h4>Canais ativos</h4><div class="badge-list">'+((p.channels||[]).map(c=>'<span class="b outline">'+c+'</span>').join('') || '<span style="font-size:12px; color:var(--eo-ink-faint)">—</span>')+'</div></div>'+
      (agents.length ? '<div class="panel-section"><h4>Supervisiona '+agents.length+' agente(s) IA</h4><div class="related">'+agents.map(a=>'<div class="row" data-jump="agent:'+a.id+'">'+avatarHTML(a.name.split(/\s+/).map(s=>s[0]).join('').slice(0,2).toUpperCase(),'agent')+'<div><div class="meta">'+a.name+'</div><div class="submeta">'+statusLabelTxt(a)+'</div></div></div>').join('')+'</div></div>' : '')+
      '<div class="panel-section"><h4>Ações</h4><div class="actions">'+((p.channels||[]).slice(0,1).map(c=>'<button class="btn primary">💬 Falar via '+c.split('·')[0].trim()+'</button>').join(''))+'<button class="btn">Histórico</button><button class="btn">Adicionar nota</button></div></div>'+
    '</div>';
  attachPanelHandlers();
  document.getElementById('selectionName').textContent = p.name;
}
function attachPanelHandlers(){
  const close = document.getElementById('panelClose');
  if (close) close.addEventListener('click', function(){ selectEntity(null); });
  panel.querySelectorAll('[data-jump]').forEach(el=>{
    el.addEventListener('click', function(){
      const parts = el.getAttribute('data-jump').split(':');
      selectEntity({type: parts[0], id: parts[1]});
    });
  });
}
function entityPosition(sel){
  if (sel.type === 'agent'){
    const a = AGENT_BY_ID[sel.id]; if (!a) return null;
    const r = ROOM_BY_KEY[a.dept];
    return iso(r.x + a.x + 0.8, r.y + a.y + 0.6, 0.9);
  } else {
    const p = PERSON_BY_ID[sel.id]; if (!p) return null;
    const r = ROOM_BY_KEY[p.dept];
    return iso(r.x + p.x + 0.5, r.y + p.y + 0.5, 1.0);
  }
}
function drawConnections(sel){
  layers.conn.innerHTML = '';
  if (!sel) return;
  const from = entityPosition(sel);
  if (!from) return;
  let targets = [];
  if (sel.type === 'agent'){
    const a = AGENT_BY_ID[sel.id];
    targets = (a.supervisor||[]).map(pid => ({type:'person', id:pid}));
  } else if (sel.type === 'person'){
    const p = PERSON_BY_ID[sel.id];
    targets = (p.supervisesAgents||[]).map(aid => ({type:'agent', id:aid}));
  }
  targets.forEach(t=>{
    const to = entityPosition(t); if (!to) return;
    const cx = (from[0]+to[0])/2;
    const cy = Math.min(from[1], to[1]) - 50;
    const path = 'M '+from[0]+' '+from[1]+' Q '+cx+' '+cy+' '+to[0]+' '+to[1];
    ELEM('path',{d:path, class:'conn'}, layers.conn);
    const node = svg.querySelector('[data-id="'+t.id+'"]');
    if (node) node.classList.add('selected');
  });
}

svg.addEventListener('click', function(e){
  if (e.target === svg) selectEntity(null);
});

let activeModel = 'all';
function applyModel(m){
  activeModel = m;
  document.querySelectorAll('#modelFilter .chip').forEach(c=>c.classList.toggle('on', c.dataset.m===m));
  document.querySelectorAll('.obj.interactive').forEach(el=>{
    const ms = (el.getAttribute('data-models')||'').split(',').filter(Boolean);
    el.classList.toggle('dim', !(m==='all' || ms.includes(m)));
  });
  applyLens(activeLens);
}
document.querySelectorAll('#modelFilter .chip').forEach(c=>{
  c.addEventListener('click', function(){ applyModel(c.dataset.m); });
});

let activeLens = 'default';
function applyLens(l){
  activeLens = l;
  document.querySelectorAll('#lensFilter .chip').forEach(c=>c.classList.toggle('on', c.dataset.l===l));
  layers.conn.innerHTML = '';
  document.querySelectorAll('.obj.selected').forEach(e=>e.classList.remove('selected'));
  if (l === 'default'){ /* nada */ }
  else if (l === 'status'){
    document.querySelectorAll('[data-kind="agent"]').forEach(el=>{
      const a = AGENT_BY_ID[el.getAttribute('data-id')];
      if (a && a.running) el.classList.add('selected');
    });
  } else if (l === 'dorm'){
    document.querySelectorAll('.obj.interactive').forEach(el=>el.classList.add('dim'));
    document.querySelectorAll('[data-kind="agent"]').forEach(el=>{
      const a = AGENT_BY_ID[el.getAttribute('data-id')];
      if (a && a.status==='dorm'){ el.classList.remove('dim'); el.classList.add('selected'); }
    });
  } else if (l === 'conn'){
    AGENTS.forEach(a => {
      const from = entityPosition({type:'agent', id:a.id});
      (a.supervisor||[]).forEach(pid=>{
        const to = entityPosition({type:'person', id:pid}); if (!to||!from) return;
        const cx=(from[0]+to[0])/2, cy=Math.min(from[1],to[1])-40;
        ELEM('path',{d:'M '+from[0]+' '+from[1]+' Q '+cx+' '+cy+' '+to[0]+' '+to[1], class:'conn', style:'opacity:.45'}, layers.conn);
      });
    });
  }
  if (activeModel !== 'all' && l !== 'dorm'){
    document.querySelectorAll('.obj.interactive').forEach(el=>{
      const ms = (el.getAttribute('data-models')||'').split(',').filter(Boolean);
      el.classList.toggle('dim', !ms.includes(activeModel));
    });
  }
}
document.querySelectorAll('#lensFilter .chip').forEach(c=>{
  c.addEventListener('click', function(){ applyLens(c.dataset.l); });
});

const q = document.getElementById('q');
q.addEventListener('input', function(e){
  const term = (e.target.value||'').trim().toLowerCase();
  if (!term){
    document.querySelectorAll('.obj.interactive').forEach(el=>el.classList.remove('dim'));
    applyModel(activeModel); applyLens(activeLens);
    return;
  }
  const matches = []
    .concat(PEOPLE.filter(p => p.name.toLowerCase().includes(term) || (p.role||'').toLowerCase().includes(term) || (p.shortName||'').toLowerCase().includes(term)))
    .concat(AGENTS.filter(a => a.name.toLowerCase().includes(term) || (a.desc||'').toLowerCase().includes(term)));
  const ids = new Set(matches.map(m=>m.id));
  document.querySelectorAll('.obj.interactive').forEach(el=>{
    el.classList.toggle('dim', !ids.has(el.getAttribute('data-id')));
  });
});

function tickLive(){
  const ts = document.getElementById('liveTs');
  if (!ts) return;
  let n = parseInt(ts.dataset.n||'12', 10);
  n = (n + 1) % 60;
  ts.dataset.n = n;
  ts.textContent = 'há '+n+'s';
}
setInterval(tickLive, 1000);

document.addEventListener('keydown', function(e){ if (e.key==='Escape') selectEntity(null); });
})();
</script>
