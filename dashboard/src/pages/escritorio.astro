(function(){
  const r = ROOM_BY_KEY['lib'];
  function estanteEste(gx, gy, len){
    const z=1.2, w=0.4, d=len;
    const top  = [iso(gx,gy,z),iso(gx+w,gy,z),iso(gx+w,gy+d,z),iso(gx,gy+d,z)];
    const front= [iso(gx,gy+d,z),iso(gx+w,gy+d,z),iso(gx+w,gy+d,0),iso(gx,gy+d,0)];
    const east = [iso(gx+w,gy,z),iso(gx+w,gy+d,z),iso(gx+w,gy+d,0),iso(gx+w,gy,0)];
    enq(gx+gy+0.25, ()=>{
      ELEM('polygon',{points: poly(east), fill:'#5d3f23'}, layers.furniture);
      ELEM('polygon',{points: poly(front), fill:'#7d5938', stroke:'rgba(0,0,0,0.18)'}, layers.furniture);
      ELEM('polygon',{points: poly(top), fill:'#8e6843', stroke:'rgba(0,0,0,0.2)'}, layers.furniture);
      const colors = ['#185fa5','#dc2626','#16a34a','#7c2d12','#475569','#9d174d','#0e7490','#854d0e'];
      const shelves = 3;
      for (let s=0; s<shelves; s++){
        const sz = z * (1 - (s+1)/(shelves+1));
        for (let bi = 0; bi < d*4; bi++){
          const by = gy + bi/(d*4) * d;
          const bh = 0.18 + Math.random()*0.08;
          const a=iso(gx, by, sz+bh), b=iso(gx, by+0.18, sz+bh);
          const a2=iso(gx, by, sz), b2=iso(gx, by+0.18, sz);
          ELEM('polygon',{points: poly([a,b,b2,a2]), fill: colors[(bi+s)%colors.length]}, layers.furniture);
        }
        const sa=iso(gx, gy, sz), sb=iso(gx+w, gy, sz);
        const sc=iso(gx+w, gy+d, sz), sd=iso(gx, gy+d, sz);
        ELEM('polygon',{points:poly([sa,sb,sc,sd]), fill:'#5d3f23', opacity:.7}, layers.furniture);
      }
    });
  }
  estanteEste(r.x + r.w - 0.4, r.y + 0.5, 5.5);
  mesaRedonda(r.x + r.w - 2.2, r.y + r.d - 1.6, 0.8, '#d8c69a');
  cadeira(r.x + r.w - 3.4, r.y + r.d - 2.4, '#3b3b39');
  cadeira(r.x + r.w - 1.4, r.y + r.d - 2.4, '#3b3b39');
  cadeira(r.x + r.w - 3.4, r.y + r.d - 0.8, '#3b3b39');
  planta(r.x + 0.2, r.y + r.d - 1.4, 'ficus');
})();

(function(){
  const r = ROOM_BY_KEY['prj'];
  function quadroProjeto(gx, gy, model){
    const h = 1.0, w = 0.95;
    const a = iso(gx, gy, h+0.4);
    const b = iso(gx + w, gy, h+0.4);
    const c = iso(gx + w, gy, h-0.05);
    const d = iso(gx, gy, h-0.05);
    enq((gx+gy)*0.5 - 0.05, ()=>{
      ELEM('polygon',{points: poly([a,b,c,d]), fill:'#fff', stroke:'#3b2f24','stroke-width':1.6}, layers.wallDecor);
      const ah = iso(gx, gy, h+0.4);
      const bh = iso(gx + w, gy, h+0.4);
      const ch = iso(gx + w, gy, h+0.32);
      const dh = iso(gx, gy, h+0.32);
      ELEM('polygon',{points: poly([ah,bh,ch,dh]), fill: model.statusColor}, layers.wallDecor);
      const cx = (a[0]+b[0])/2, cy = (a[1]+c[1])/2;
      const t = ELEM('text',{x:cx, y:cy+4, 'text-anchor':'middle', 'font-size':22, 'font-weight':800, fill:'#1a1a18', 'letter-spacing':'.04em'}, layers.wallDecor);
      t.textContent = model.letter;
      const sub = ELEM('text',{x:cx, y:c[1]-6, 'text-anchor':'middle', 'font-size':7, 'font-weight':600, fill:'#5a5a55'}, layers.wallDecor);
      sub.textContent = model.name.toUpperCase();
      const stat = ELEM('text',{x:cx, y:c[1]+2, 'text-anchor':'middle', 'font-size':6.5, 'font-weight':700, fill: model.statusColor, 'letter-spacing':'.06em'}, layers.wallDecor);
      stat.textContent = model.status.toUpperCase();
    });
  }
  const wallWidth = r.w - 0.4;
  const slot = wallWidth / 6;
  PROJETOS_BOARDS.forEach((m, i) => {
    quadroProjeto(r.x + 0.2 + i * slot + (slot - 0.95)/2, r.y + 0.02, m);
  });
  sofa(r.x + 0.6, r.y + 2.0, 6.5, '#7c8aa6');
  mesaCafe(r.x + 1.4, r.y + 1.2, '#6b4b25');
  mesaCafe(r.x + 5.4, r.y + 1.2, '#6b4b25');
  planta(r.x + 0.2, r.y + 5.4, 'palm');
  planta(r.x + r.w - 1.2, r.y + 5.4, 'ficus');
  planta(r.x + r.w - 1.2, r.y + 1.2, 'small');
})();

