---
import EscritorioBase from "../../layouts/EscritorioBase.astro";
import AvatarTiny from "../../components/escritorio/AvatarTiny.astro";
import { ORDEM_PROJETOS, META_PROJETOS, SAUDE_COR, KIND_HUMANO } from "../../data/escritorio-meta";
import { TODAS_PESSOAS } from "../../data/pessoas";
import { AGENTES } from "../../data/agentes";
import { tarefasAbertasDoProjeto } from "../../data/tarefas-escritorio";
import { FEED } from "../../data/feed";
import { DECISOES } from "../../data/decisoes";

const alertasCriticos = DECISOES.filter((d) => d.priority === "critica");
const alertasWarn     = DECISOES.filter((d) => d.priority === "alta");
const decisoesAguard  = DECISOES.length;

const kpiAgentesAtivos = AGENTES.filter((a) => a.fase === "ativo").length;
const kpiAgentesRunning = 3;
const kpiHumanos = `${TODAS_PESSOAS.filter((p) => ["augusto","pablo","antonio","andressa","cynthia"].includes(p.id)).length}/7`;
const kpiReceita = "$2k+";

const feedRecente = FEED.slice(0, 7);

function avKindOf(authorAvatarKind: "agent" | "nucleo" | "exec" | "orbit" | "client") {
  return authorAvatarKind;
}
---

<EscritorioBase
  title="Mission Control"
  subtitle="Tudo numa tela. Alertas no topo, projetos no centro, feed à direita. Pulse de operação Bloomberg-style."
>
  <div class="mc-alerts">
    {alertasCriticos.map((a) => (
      <div class="mc-alert critico" data-projeto={a.projectId} data-visibilidade={a.visibleTo.join(",")}>
        <span class="dot"></span>{a.projectId} · {a.title.replace(/^Decidir: */, "")}
        <span class="ago">{a.ageLabel}</span>
      </div>
    ))}
    {alertasWarn.map((a) => (
      <div class="mc-alert amber" data-projeto={a.projectId} data-visibilidade={a.visibleTo.join(",")}>
        <span class="dot"></span>{a.projectId} · {a.title.replace(/^Aprovar */, "Aprovar ")} <span class="ago">{a.ageLabel}</span>
      </div>
    ))}
    <div class="mc-alert info">
      <span class="dot"></span>{decisoesAguard} decisões aguardam aprovação
    </div>
  </div>

  <div class="mc-grid">
    <div>
      <div class="mc-projects">
        {ORDEM_PROJETOS.map((id) => {
          const m = META_PROJETOS[id];
          const tarefas = tarefasAbertasDoProjeto(id);
          const criticas = tarefas.filter((t) => t.state === "critica").length;
          const humanos = TODAS_PESSOAS.filter((p) => p.modelos.includes(id) && KIND_HUMANO[p.id] !== "client").slice(0, 3);
          const sideClass =
            m.saude === "critico" ? "alert" :
            m.saude === "alerta"  ? "warn"  :
            m.saude === "ok"      ? "ok"    :
            m.saude === "dormente"? "dim"   : "";
          return (
            <a
              href={`/projetos/${id}`}
              class:list={["mc-prj", sideClass]}
              data-projeto={id}
            >
              <div class="head">
                <div>
                  <span class="letter">{m.letra}</span>
                  <span class="name">{m.apelido}</span>
                </div>
                <span class="health" style={`background:${SAUDE_COR[m.saude]}`}></span>
              </div>
              <div class="row">
                <span>{m.receita.split("·")[0].trim()}</span>
                <b>{m.agentesAtivos} agentes ativos</b>
              </div>
              <div class="row">
                <span>{tarefas.length} tarefas{criticas > 0 ? ` (${criticas} crítica${criticas === 1 ? "" : "s"})` : ""}</span>
                <span>{humanos.map((h) => h.iniciais).join(", ") || "—"}</span>
              </div>
              <div class="next">Próxima · {m.proximaAcao}</div>
            </a>
          );
        })}
      </div>

      <div class="mc-kpis">
        <div class="kpi"><div class="v">{kpiAgentesAtivos}</div><div class="l">agentes ativos</div></div>
        <div class="kpi"><div class="v">{kpiAgentesRunning}</div><div class="l">rodando agora</div></div>
        <div class="kpi"><div class="v">{kpiReceita}</div><div class="l">receita ativa A</div></div>
        <div class="kpi"><div class="v">{kpiHumanos}</div><div class="l">humanos online</div></div>
      </div>
    </div>

    <aside class="mc-feed">
      <h4>Feed ao vivo · últimos eventos</h4>
      {feedRecente.map((f) => (
        <div class="feed-item" data-projeto={f.projectId}>
          <AvatarTiny
            ownerId={f.authorId}
            ownerKind={f.authorKind === "human" ? "human" : "agent"}
            iniciais={f.authorLabel.slice(0, 2).toUpperCase()}
            kind={avKindOf(f.authorAvatarKind)}
            size="tiny"
          />
          <div class="body">
            <div><span class="who">{f.authorLabel}</span> <span class="what" set:html={f.text.replace(/<[^>]+>/g, "").slice(0, 80)}></span></div>
            <div class="ago">{f.timeLabel}{f.awaitingLabel ? ` · ${f.awaitingLabel}` : ""}</div>
          </div>
        </div>
      ))}
    </aside>
  </div>
</EscritorioBase>

<style>
  .mc-alerts { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 12px; }
  .mc-alert {
    display: flex; gap: 8px; align-items: center;
    padding: 8px 12px; border-radius: 8px;
    font-size: 12px; font-weight: 500;
    background: var(--color-info-bg); color: var(--color-info-text);
    border: 1px solid color-mix(in srgb, var(--color-info-text) 14%, transparent);
  }
  .mc-alert.critico { background: var(--color-danger-bg); color: var(--color-danger-text); border-color: color-mix(in srgb, var(--color-danger-text) 18%, transparent); }
  .mc-alert.amber   { background: var(--color-warning-bg); color: var(--color-warning-text); border-color: color-mix(in srgb, var(--color-warning-text) 18%, transparent); }
  .mc-alert .dot { width: 7px; height: 7px; border-radius: 50%; background: currentColor; }
  .mc-alert .ago { font-size: 11px; opacity: .75; font-weight: 400; }

  .mc-grid { display: grid; grid-template-columns: 1fr 320px; gap: 14px; }
  @media (max-width: 1024px) { .mc-grid { grid-template-columns: 1fr; } }

  .mc-projects { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }
  @media (max-width: 720px) { .mc-projects { grid-template-columns: repeat(2, 1fr); } }

  .mc-prj {
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: 10px; padding: 12px;
    display: flex; flex-direction: column; gap: 6px;
    cursor: pointer; text-decoration: none; color: inherit;
    transition: all .12s;
  }
  .mc-prj:hover { border-color: var(--color-line-strong); box-shadow: 0 8px 24px -12px rgba(0,0,0,.18); }
  .mc-prj.alert { border-left: 3px solid #dc2626; }
  .mc-prj.warn  { border-left: 3px solid #d97706; }
  .mc-prj.ok    { border-left: 3px solid #16a34a; }
  .mc-prj.dim   { opacity: .55; }

  .mc-prj .head { display: flex; justify-content: space-between; align-items: baseline; }
  .mc-prj .letter { font-size: 18px; font-weight: 600; }
  .mc-prj .name   { font-size: 12.5px; font-weight: 500; color: var(--color-soft); margin-left: 6px; }
  .mc-prj .health { display: inline-block; width: 9px; height: 9px; border-radius: 50%; }
  .mc-prj .row    { display: flex; justify-content: space-between; font-size: 11.5px; color: var(--color-soft); margin-top: 2px; }
  .mc-prj .row b  { color: var(--color-base); font-weight: 500; }
  .mc-prj .next   { font-size: 11px; color: var(--color-faint); margin-top: 4px; padding-top: 4px; border-top: 1px dashed var(--color-line); }

  .mc-feed {
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: 10px; padding: 12px;
    max-height: 540px; overflow: auto;
  }
  .mc-feed h4 {
    font-size: 11px; font-weight: 600;
    text-transform: uppercase; letter-spacing: .08em;
    color: var(--color-faint); margin: 0 0 8px;
  }
  .feed-item {
    display: flex; gap: 8px; padding: 7px 0;
    border-bottom: 1px dashed var(--color-line);
    font-size: 12px; align-items: flex-start;
  }
  .feed-item:last-child { border-bottom: 0; }
  .feed-item .body { flex: 1; min-width: 0; }
  .feed-item .who  { font-weight: 500; }
  .feed-item .what { color: var(--color-soft); }
  .feed-item .ago  { font-size: 10.5px; color: var(--color-faint); margin-top: 2px; }

  .mc-kpis { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin-top: 14px; }
  @media (max-width: 640px) { .mc-kpis { grid-template-columns: repeat(2, 1fr); } }
  .kpi { background: var(--color-muted); padding: 10px 12px; border-radius: 8px; }
  .kpi .v { font-size: 18px; font-weight: 600; }
  .kpi .l { font-size: 10.5px; color: var(--color-faint); text-transform: uppercase; letter-spacing: .05em; margin-top: 2px; }
</style>
