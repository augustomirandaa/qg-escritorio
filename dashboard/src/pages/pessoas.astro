---
import Base from "../layouts/Base.astro";
import { NUCLEO, EXECUTORES, NETWORK, CLIENTES, TIPO_LABELS } from "../data/pessoas";
import { PROJETOS } from "../data/projetos";
import type { Pessoa } from "../data/types";

const grupos: { titulo: string; descricao: string; pessoas: Pessoa[] }[] = [
  {
    titulo: "Núcleo · sabe do macro",
    descricao: "Os 3 sócios. Sabem da saída, modelos pós-saída, decisões estratégicas.",
    pessoas: NUCLEO,
  },
  {
    titulo: "Executores · escopo limitado",
    descricao: "Operam pauta sem visibilidade do contexto macro. Recebem instruções operacionais (formato/prazo/material).",
    pessoas: EXECUTORES,
  },
  {
    titulo: "Pessoas que orbitam",
    descricao: "Não são humanos do QG, mas tocam parte da operação. Mapeados separadamente por terem dupla função ou parceria de network.",
    pessoas: NETWORK,
  },
  {
    titulo: "Clientes · relações externas",
    descricao: "Clientes high-touch dos modelos. Não trabalham no QG — são pra quem o QG entrega. Aparecem aqui porque o relacionamento é parte da operação estratégica.",
    pessoas: CLIENTES,
  },
];
---

<Base
  title="Pessoas"
  subtitle="Quem está no QG · núcleo, executores e órbita"
>
  {grupos.map((g) => (
    <section class="mb-7">
      <h2 class="text-[15px] font-medium mb-1">{g.titulo}</h2>
      <p class="text-[12px] text-soft mb-3 leading-snug max-w-[680px]">{g.descricao}</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {g.pessoas.map((p) => (
          <div class="panel">
            <div class="flex items-start gap-3">
              <div class:list={["av", `t-${p.tipo}`]}>{p.iniciais}</div>
              <div class="flex-1 min-w-0">
                <div class="flex items-baseline justify-between gap-2 flex-wrap">
                  <div class="text-[14px] font-medium leading-tight">{p.nome}</div>
                  {p.custoMensal && (
                    <span class="text-[10px] text-faint whitespace-nowrap">{p.custoMensal}/mês</span>
                  )}
                </div>
                <div class="text-[12px] text-soft mt-0.5">{p.papel}</div>
                <p class="text-[12px] text-soft mt-2.5 leading-snug m-0">{p.descricao}</p>
                <div class="flex items-center gap-2 mt-3 flex-wrap">
                  <span class="text-[10px] text-faint">{TIPO_LABELS[p.tipo]}</span>
                  <span class="w-1 h-1 rounded-full bg-faint"></span>
                  <span class="text-[10px] text-faint">
                    {p.saberContextoMacro ? "macro: sim" : "macro: não"}
                  </span>
                </div>
                <div class="flex items-center gap-1 mt-2.5 flex-wrap">
                  {p.modelos.map((m) => (
                    <a
                      href={`/projetos/${m}`}
                      class="text-[10px] px-1.5 py-0.5 rounded bg-muted text-soft hover:bg-canvas hover:text-base transition-colors"
                      title={PROJETOS[m].apelido}
                    >
                      {m} · {PROJETOS[m].apelido}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>
  ))}
</Base>

<style>
  .av {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 500;
    color: #fff;
    flex-shrink: 0;
  }
  .av.t-socio { background: var(--color-avatar-socio); }
  .av.t-hibrida { background: var(--color-avatar-hibrida); }
  .av.t-executor { background: var(--color-avatar-executor); }
  .av.t-network { background: var(--color-avatar-network); }
  .av.t-cliente { background: var(--color-avatar-cliente); }
</style>
