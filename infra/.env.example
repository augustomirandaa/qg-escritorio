# .env.example · template das variáveis de ambiente
#
# COPIE pra .env e preencha os valores reais:
#   cp .env.example .env
#
# .env é gitignored · NUNCA commit
#
# Gerar valores seguros:
#   openssl rand -base64 32     # pra secrets gerais
#   openssl rand -hex 32        # pra tokens hex
#   pwgen -s 32 1               # pra senhas alfanuméricas

# ─── Domínio ───────────────────────────────────────────────────────────────

# Domínio principal pro chat (ex: qg.augustomiranda.com)
DOMAIN=qg.example.com

# Email pra Let's Encrypt (recebe notificação de expiração de cert)
EMAIL_TLS=augustomirandaa@gmail.com

# ─── Anthropic Claude API ──────────────────────────────────────────────────

# Chave da API · pega em https://console.anthropic.com
# Custo estimado inicial: $50-150/mês dependendo do uso
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Postgres ──────────────────────────────────────────────────────────────

POSTGRES_USER=qg
POSTGRES_PASSWORD=CHANGE_ME_use_openssl_rand_base64_32
POSTGRES_DB=qg

# ─── Redis ─────────────────────────────────────────────────────────────────

REDIS_PASSWORD=CHANGE_ME_use_openssl_rand_base64_32

# ─── Anything LLM · secrets internos ───────────────────────────────────────

# Gere com: openssl rand -hex 32
ANYTHINGLLM_JWT_SECRET=CHANGE_ME_64_hex_chars
ANYTHINGLLM_SIG_KEY=CHANGE_ME_64_hex_chars
ANYTHINGLLM_SIG_SALT=CHANGE_ME_64_hex_chars

# ─── Notion (pra sync · deixe vazio até implementar) ──────────────────────

# Integration token · criar em https://www.notion.so/my-integrations
NOTION_API_TOKEN=

# ID da página QG no Notion (último segmento da URL · 32 chars sem hífens)
NOTION_WORKSPACE_PAGE_ID=

# ─── WhatsApp Business Cloud API (pra MCP · deixe vazio até implementar) ──

# Token de verificação que VOCÊ define no Meta Developer Console
WHATSAPP_VERIFY_TOKEN=

# Permanent access token gerado no Meta Developer Console
WHATSAPP_ACCESS_TOKEN=

# Phone number ID do WhatsApp Business
WHATSAPP_PHONE_NUMBER_ID=

# ─── Embedding provider · default native (Anything LLM) ────────────────────

# Se for usar OpenAI pra embeddings (qualidade superior · custo extra):
# EMBEDDING_ENGINE=openai
# OPENAI_API_KEY=sk-XXXXX
# EMBEDDING_MODEL_PREF=text-embedding-3-small
